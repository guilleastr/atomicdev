#!/bin/sh
# Atomic Dev pre-commit hook
# Triggers Docs Creator when changes are committed.

set -e

SKILLS_DIR=".agents/skills"
CHANGED=$(git diff --cached --name-only)

# Skip if no files changed
if [ -z "$CHANGED" ]; then
  exit 0
fi

# Skip if Atomic Dev is not installed
if [ ! -d "$SKILLS_DIR" ]; then
  exit 0
fi

# Run Docs Creator via the configured IDE CLI
# Claude Code
if command -v claude >/dev/null 2>&1; then
  claude --skill docs-creator --diff "$CHANGED"
# GitHub Copilot (via gh CLI extension)
elif command -v gh >/dev/null 2>&1 && gh extension list 2>/dev/null | grep -q "copilot"; then
  gh copilot skill docs-creator --diff "$CHANGED"
else
  # Fallback — print a reminder if no CLI is available
  echo "[Atomic Dev] No agent CLI detected. Docs Creator skipped."
  echo "[Atomic Dev] Install Claude Code or GitHub Copilot CLI to enable automatic documentation."
  exit 0
fi

# Stage any updated skill artifacts
if [ -d "$SKILLS_DIR" ]; then
  git add "$SKILLS_DIR/"
fi

exit 0
