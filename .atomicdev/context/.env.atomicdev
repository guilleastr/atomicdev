{
  "framework": {
    "version": "0.1.0",
    "name": "Atomic Dev"
  },
  "paths": {
    "wiki_path": "./docs/wiki",
    "artifacts_path": "./.agents/artifacts",
    "outputs_path": "./docs/generated"
  },
  "documentation": {
    "commit_message_template": "atomic-dev"
  },
  "integrations": {
    "enabled_services": ["git", "pre-commit"],
    "external_wiki": null
  },
  "behavior": {
    "auto_create_repo_skills": true
  }
}
